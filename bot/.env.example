# Discord
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Optional: speed up slash command registration
DISCORD_GUILD_ID=

# Backend
BACKEND_URL=http://localhost:4000
# Optional override, otherwise derived from BACKEND_URL
# BACKEND_WS_URL=ws://localhost:4000/ws
# Optional: request a specific worker capability (example: youtube_firefox)
# BOT_COOKIE_METHOD=youtube_firefox

# Bot backend credentials (create a local user in the backend auth system)
BOT_BACKEND_USERNAME=
BOT_BACKEND_PASSWORD=
