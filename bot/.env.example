# ── Discord ────────────────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Application ID (Client ID) from the Developer Portal
DISCORD_CLIENT_ID=

# Guild ID for instant guild-scoped command registration (faster than global).
# Leave blank to register commands globally (takes up to 1 hour to propagate).
DISCORD_GUILD_ID=

# ── Backend ────────────────────────────────────────────────────────────────────
# HTTP base URL of your SpotiSync backend (no trailing slash)
# Example Railway internal URL: https://spotisync-backend.up.railway.app
BACKEND_URL=http://localhost:4000

# WebSocket URL of your SpotiSync backend.
# If left blank, derived automatically from BACKEND_URL (http→ws, https→wss) + /ws
# Per STANDARDS.md the bot authenticates via: ws://<host>/ws?token=<JWT>
BACKEND_WS_URL=

# Credentials for the bot's backend account.
# Create a dedicated bot user via POST /api/auth/register before deploying.
BOT_BACKEND_USERNAME=
BOT_BACKEND_PASSWORD=

# ── Optional ───────────────────────────────────────────────────────────────────
# Passed as ?cookieMethod=<value> to GET /api/media/resolve/:videoId
# Only needed if your worker supports multiple cookie strategies.
BOT_COOKIE_METHOD=

# Discord user ID of the bot owner (used for /ban permission bypass).
OWNER_ID=756572353911062550
