PORT=4000
NODE_ENV=production

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/jammode

# JWT
JWT_SECRET=change_me_to_a_random_secret_at_least_32_chars
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=30
# Required for cross-site cookies between Railway apps
COOKIE_SAMESITE=none
# Set when using a custom domain (optional)
# COOKIE_DOMAIN=yourdomain.com

# CORS - comma separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,https://spotisync-copy-production.up.railway.app

# Redis
REDIS_URL=redis://localhost:6379

# Google OAuth
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Room heartbeat interval (ms) - how often host sends heartbeat
HEARTBEAT_INTERVAL_MS=10000
# Room timeout (ms) - how long before a room without heartbeat is closed
ROOM_TIMEOUT_MS=30000
# Room janitor: how often to run cleanup (ms) and how long to keep inactive rooms (hours)
ROOM_CLEANUP_INTERVAL_MS=300000
ROOM_RETENTION_HOURS=24

# Voting defaults
DEFAULT_VOTE_THRESHOLD=0.5
# Cooldown between votes in seconds (0 = no cooldown)
VOTE_COOLDOWN_SEC=5

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Cookie worker coordinator (media proxy)
COOKIE_WORKER_AUTH_TOKEN=change_me_shared_secret_for_cookie_workers
# Max time to wait for an assigned worker to finish one job
MEDIA_WORKER_JOB_TIMEOUT_MS=15000
# Worker heartbeat freshness window
MEDIA_WORKER_TTL_MS=20000
# How long to keep completed/failed jobs in memory
MEDIA_MAX_JOB_AGE_MS=300000
# Backend stream proxy token TTL (ms)
MEDIA_STREAM_PROXY_TTL_MS=120000
# Backend stream proxy wait time for worker to be ready (ms)
MEDIA_STREAM_PROXY_READY_TIMEOUT_MS=10000
