BACKEND_URL=http://localhost:4000
WORKER_ID=cookie-worker-1
WORKER_TOKEN=change_me_to_match_backend_COOKIE_WORKER_AUTH_TOKEN
WORKER_COOKIES_BROWSER=chrome

# Optional
# Public base URL that clients (bot/frontend) can reach for the worker stream.
# IMPORTANT: Do NOT use localhost unless the bot is running on the same machine.
# Example: http://your-public-ip:4011 or https://worker.example.com
# WORKER_PUBLIC_BASE_URL=http://your-public-ip:4011
# WORKER_STREAM_PORT=4011
# WORKER_STREAM_HOST=0.0.0.0
# WORKER_COOKIES_PROFILE=Default
# WORKER_POLL_INTERVAL_MS=3000
# WORKER_HEARTBEAT_INTERVAL_MS=10000
# YTDLP_BIN=yt-dlp
